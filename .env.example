# NuDashboard Environment Variables
# Copy this to .env.local for local development

# Supabase (optional — only needed for auth via Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Fallback local auth password (used when Supabase is not configured)
VITE_DASHBOARD_PASSWORD=nudental2024
